# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and NEVER committed.

# Supabase project credentials (Supabase Dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
# Use the service_role key (not the anon key) — required for server-side writes
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Session signing secret — generate with: openssl rand -hex 64
SESSION_SECRET=replace_with_64_byte_hex_secret

# User passwords — set strong unique passwords, never commit real values
PW_MARCUS=change_me
PW_SARAH=change_me
PW_ALEX=change_me
PW_DERRICK=change_me
